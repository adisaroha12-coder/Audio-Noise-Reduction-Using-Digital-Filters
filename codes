# 1. IMPORT LIBRARIES
import numpy as np
import scipy.signal as signal
import matplotlib.pyplot as plt
from IPython.display import Audio, display

# 2. GENERATE MULTI-FREQUENCY SIGNAL
fs = 44100
t = np.linspace(0, 2, fs*2)

# Signal components
sig1 = 0.5*np.sin(2*np.pi*100*t)    # Low freq
sig2 = 0.5*np.sin(2*np.pi*440*t)    # Mid freq
sig3 = 0.5*np.sin(2*np.pi*1000*t)   # High freq

clean = sig1 + sig2 + sig3

# Add noise
noise = 0.4*np.random.randn(len(t))
noisy = clean + noise

# Normalize
noisy = noisy / np.max(np.abs(noisy))

# 3. FILTER DESIGN (IIR BUTTERWORTH)
nyq = 0.5 * fs

# Low-pass (cutoff = 500 Hz)
lpf = signal.butter(4, 500/nyq, btype='low', output='sos')
lpf_out = signal.sosfiltfilt(lpf, noisy)

# High-pass (cutoff = 500 Hz)
hpf = signal.butter(4, 500/nyq, btype='high', output='sos')
hpf_out = signal.sosfiltfilt(hpf, noisy)

# Band-pass (400–480 Hz)
bpf = signal.butter(4, [400/nyq, 480/nyq], btype='band', output='sos')
bpf_out = signal.sosfiltfilt(bpf, noisy)

# Band-stop (remove 440 Hz band)
bsf = signal.butter(4, [400/nyq, 480/nyq], btype='bandstop', output='sos')
bsf_out = signal.sosfiltfilt(bsf, noisy)

# 4. TIME DOMAIN (ZOOMED)
plt.figure(figsize=(10,6))

plt.plot(noisy[:1000], label="Noisy")
plt.plot(lpf_out[:1000], label="LPF")
plt.plot(hpf_out[:1000], label="HPF")
plt.plot(bpf_out[:1000], label="BPF")
plt.plot(bsf_out[:1000], label="BSF")

plt.legend()
plt.title("Time Domain Comparison (Zoomed)")
plt.show()

# 5. FFT FUNCTION
def plot_fft(sig, fs, title):
    N = len(sig)
    fft_vals = np.abs(np.fft.fft(sig)) / N
    freqs = np.fft.fftfreq(N, 1/fs)

    mask = freqs >= 0

    plt.figure()
    plt.plot(freqs[mask], fft_vals[mask])
    plt.title(title)
    plt.xlabel("Frequency (Hz)")
    plt.ylabel("Magnitude")
    plt.grid()
    plt.show()


# 6. FREQUENCY DOMAIN
plot_fft(noisy, fs, "Noisy FFT")
plot_fft(lpf_out, fs, "LPF FFT")
plot_fft(hpf_out, fs, "HPF FFT")
plot_fft(bpf_out, fs, "BPF FFT")
plot_fft(bsf_out, fs, "BSF FFT")


# 7. SPECTROGRAM
plt.figure(figsize=(10,8))

plt.subplot(5,1,1)
plt.specgram(noisy, Fs=fs)
plt.title("Noisy")

plt.subplot(5,1,2)
plt.specgram(lpf_out, Fs=fs)
plt.title("LPF")

plt.subplot(5,1,3)
plt.specgram(hpf_out, Fs=fs)
plt.title("HPF")

plt.subplot(5,1,4)
plt.specgram(bpf_out, Fs=fs)
plt.title("BPF")

plt.subplot(5,1,5)
plt.specgram(bsf_out, Fs=fs)
plt.title("BSF")

plt.tight_layout()
plt.show()


# 8. AUDIO PLAYBACK
print("Noisy:")
display(Audio(noisy, rate=fs))

print("LPF:")
display(Audio(lpf_out, rate=fs))

print("HPF:")
display(Audio(hpf_out, rate=fs))

print("BPF:")
display(Audio(bpf_out, rate=fs))

print("BSF:")
display(Audio(bsf_out, rate=fs))
